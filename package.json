{
  "name": "expertenglish",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev": "cross-env ENVFILE=.env.dev expo start --dev-client",
    "start:prod": "cross-env ENVFILE=.env.production expo start --dev-client",
    "ios:dev": "cross-env ENVFILE=.env.dev expo run:ios",
    "ios:prod": "cross-env ENVFILE=.env.production expo run:ios",
    "android:dev": "cross-env ENVFILE=.env.dev expo run:android",
    "android:prod": "cross-env ENVFILE=.env.production expo run:android",
    "prebuild:android": "cross-env expo prebuild --clean --platform android",
    "prebuild:ios": "cross-env expo prebuild --clean --platform ios",
    "ios": "expo run:ios",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "generate-icons": "node scripts/generate-icons.js",
    "type-check": "tsc --noEmit",
    "android": "expo run:android",
    "build:dev": "eas build --profile develop",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "build:apk:dev": "cross-env ENVFILE=.env.dev eas build --profile develop-apk --platform android ",
    "build:apk:prod": "cross-env ENVFILE=.env.production eas build --profile production-apk --platform android ",
    "build:apk:dev:cloud": "cross-env ENVFILE=.env.dev eas build --profile develop-apk --platform android",
    "build:apk:prod:cloud": "cross-env ENVFILE=.env.production eas build --profile production-apk --platform android",
    "build:aab:prod": "cross-env ENVFILE=.env.production eas build --profile production-release --platform android ",
    "build:aab:prod:cloud": "cross-env ENVFILE=.env.production eas build --profile production-release --platform android",
    "build:ios:release:dev": "cross-env ENVFILE=.env.dev npm run prebuild:ios && open ios/*.xcworkspace",
    "build:ios:release:prod": "cross-env ENVFILE=.env.production npm run prebuild:ios && open ios/*.xcworkspace",
    "prebuild": "expo prebuild",
    "prebuild:dev": "cross-env ENVFILE=.env.dev expo prebuild",
    "prebuild:prod": "cross-env ENVFILE=.env.production expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "format:check": "prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "web": "expo start --web",
    "prepare": "husky",
    "svgr": "svgr ./assets/svgs --out-dir ./assets/svgs/output --icon --typescript --native --no-prettier"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.6.16",
    "@sentry/react-native": "^7.9.0",
    "axios": "^1.13.6",
    "expo": "~54.0.31",
    "expo-audio": "~55.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.21",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "lodash.throttle": "^4.1.1",
    "lottie-react-native": "^7.3.5",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.20.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "reactotron-react-native": "^5.1.18",
    "reactotron-redux": "^3.2.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@svgr/cli": "^8.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.2.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
