# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Environment variables - NEVER commit these
.env
.env.local
.env.development
.env.test
.env.production

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# SVG output - ignore generated icons but keep index
assets/svgs/output/*.tsx
!assets/svgs/output/index.ts

# typescript
*.tsbuildinfo

# Testing
coverage/
.nyc_output/

app-example

# generated native folders
/ios
/android
