{
  "expo": {
    "name": "ExpertEnglish",
    "slug": "ExpertEnglish",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/icon-app.png",

    "scheme": "expertenglish",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/images/icon-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icon-app.png"
    },

    "android": {
      "icon": "./assets/images/icon-app.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-app.png",
        "backgroundColor": "#0A4A6B"
      },
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/icon-app.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/icon-app.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "experenglish",
          "organization": "anh-tu-studio"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
