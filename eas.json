{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "develop-apk": {
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "develop-apk": {
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://prolingo-be.iuptit.com",
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_DEBUG_MODE": "true",
        "SENTRY_ORG": "anh-tu-studio",
        "SENTRY_PROJECT": "experenglish"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "staging",
        "SENTRY_ORG": "anh-tu-studio",
        "SENTRY_PROJECT": "experenglish"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "SENTRY_ORG": "anh-tu-studio",
        "SENTRY_PROJECT": "experenglish"
      }
    },
    "production-release": {
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "SENTRY_ORG": "anh-tu-studio",
        "SENTRY_PROJECT": "experenglish"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "SENTRY_ORG": "anh-tu-studio",
        "SENTRY_PROJECT": "experenglish"
      }
    }
  }
}
